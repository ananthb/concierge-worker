<!DOCTYPE HTML>
<html lang="{{ language }}" class="{{ default_theme }} sidebar-visible" dir="{{ text_direction }}">
<head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>
    {{#if is_print }}
    <meta name="robots" content="noindex">
    {{/if}}
    {{#if base_url}}
    <base href="{{ base_url }}">
    {{/if}}

    {{> head}}

    <meta name="description" content="{{ description }}">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#e86a2c">

    <link rel="icon" type="image/svg+xml" href="https://concierge.calculon.tech/logo.svg">

    <!-- mdBook defaults — we keep them so search, code-block highlighting, and
         the sidebar's JS plumbing all work out of the box. Our own CSS rides
         after them via additional-css and shadows whatever it needs to. -->
    <link rel="stylesheet" href="{{ resource "css/variables.css" }}">
    <link rel="stylesheet" href="{{ resource "css/general.css" }}">
    <link rel="stylesheet" href="{{ resource "css/chrome.css" }}">
    <link rel="stylesheet" href="{{ resource "fonts/fonts.css" }}">
    <link rel="stylesheet" id="mdbook-highlight-css" href="{{ resource "highlight.css" }}">

    {{#each additional_css}}
    <link rel="stylesheet" href="{{ resource this }}">
    {{/each}}

    <script>
        const path_to_root = "{{ path_to_root }}";
        const default_light_theme = "{{ default_theme }}";
        const default_dark_theme = "{{ preferred_dark_theme }}";
        {{#if search_js}}
        window.path_to_searchindex_js = "{{ resource "searchindex.js" }}";
        {{/if}}
    </script>
    <script src="{{ resource "toc.js" }}"></script>
</head>
<body>

<!-- ====================== TOPBAR ====================== -->
<header class="topbar">
    <a href="{{ path_to_root }}index.html" class="topbar__brand">
        <span class="topbar__brand-mark">C</span>
        <span class="topbar__title">Concierge</span>
    </a>
    <span class="topbar__divider"></span>
    <span class="topbar__product"><strong>Documentation</strong></span>

    {{#if search_enabled}}
    <div class="topbar__search">
        <svg class="topbar__search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        <input class="topbar__search-input" id="searchbar" name="searchbar" type="search" placeholder="Search the docs…" aria-controls="searchresults-outer" aria-describedby="searchresults-header" autocomplete="off" spellcheck="false">
        <span class="topbar__kbd">/</span>
    </div>
    {{/if}}

    <nav class="topbar__nav">
        <a href="https://concierge.calculon.tech">Hosted&nbsp;app↗</a>
        <a href="{{ path_to_root }}api/concierge/">API&nbsp;ref↗</a>
        <a href="https://github.com/ananthb/concierge" class="topbar__cta">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2 0 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.3 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 3 .1 3.2.8.9 1.2 2 1.2 3.2 0 4.6-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/></svg>
            ananthb/concierge
        </a>
    </nav>
</header>

<!-- ====================== SHELL ====================== -->
<div class="shell">

    <!-- Hidden mdbook sidebar toggle so we can collapse on narrow screens -->
    <input type="checkbox" id="mdbook-sidebar-toggle-anchor" class="hidden" checked>

    <!-- Sidebar populated by mdbook's toc.js from SUMMARY.md.
         We style the resulting <ol class="chapter"> via docs.css so it matches
         our hand-rolled .sidebar look (grouped sections, current-page accent,
         monospace group labels). -->
    <aside class="sidebar" id="mdbook-sidebar" aria-label="Documentation navigation">
        <mdbook-sidebar-scrollbox class="sidebar-scrollbox"></mdbook-sidebar-scrollbox>
        <noscript>
            <iframe class="sidebar-iframe-outer" src="{{ path_to_root }}toc.html"></iframe>
        </noscript>
    </aside>

    <main class="content">
        <div class="content__main prose">

            {{#if search_enabled}}
            <!-- Inline search results pane; mdbook's searcher.js targets these. -->
            <div id="search-wrapper" class="hidden">
                <div id="searchresults-outer" class="searchresults-outer hidden">
                    <div id="searchresults-header"></div>
                    <ul id="searchresults"></ul>
                </div>
            </div>
            {{/if}}

            {{{ content }}}

            <!-- Prev / next pager auto-populated from SUMMARY.md ordering. -->
            <nav class="pagernav" aria-label="Page navigation">
                {{#if previous}}
                <a rel="prev" href="{{ path_to_root }}{{previous.link}}" class="pagernav__item">
                    <div class="pagernav__dir">← Previous</div>
                    <div class="pagernav__title">{{previous.title}}</div>
                </a>
                {{else}}<span></span>{{/if}}

                {{#if next}}
                <a rel="next prefetch" href="{{ path_to_root }}{{next.link}}" class="pagernav__item pagernav__item--next">
                    <div class="pagernav__dir">Next →</div>
                    <div class="pagernav__title">{{next.title}}</div>
                </a>
                {{else}}<span></span>{{/if}}
            </nav>

            <footer class="docfoot">
                <a href="https://github.com/ananthb/concierge">Open&#8209;source</a>
                <span>·</span>
                <a href="https://www.gnu.org/licenses/agpl-3.0.html">AGPL&#8209;3.0</a>
                <span>·</span>
                <a href="{{ path_to_root }}api/concierge/">API reference</a>
                {{#if git_repository_edit_url}}
                <span>·</span>
                <a href="{{ git_repository_edit_url }}" rel="edit">Edit this page on GitHub</a>
                {{/if}}
            </footer>

        </div>
    </main>
</div>

<template id="fa-eye"></template>
<template id="fa-eye-slash"></template>
<template id="fa-copy"></template>
<template id="fa-play"></template>
<template id="fa-clock-rotate-left"></template>

{{#if live_reload_endpoint}}
<script>
    const wsProtocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
    const wsAddress = wsProtocol + "//" + location.host + "/" + "{{{live_reload_endpoint}}}";
    const socket = new WebSocket(wsAddress);
    socket.onmessage = function (event) {
        if (event.data === "reload") { socket.close(); location.reload(); }
    };
    window.onbeforeunload = function() { socket.close(); }
</script>
{{/if}}

{{#if search_js}}
<script src="{{ resource "elasticlunr.min.js" }}"></script>
<script src="{{ resource "mark.min.js" }}"></script>
<script src="{{ resource "searcher.js" }}"></script>
{{/if}}

<script src="{{ resource "clipboard.min.js" }}"></script>
<script src="{{ resource "highlight.js" }}"></script>
<script src="{{ resource "book.js" }}"></script>

</body>
</html>
